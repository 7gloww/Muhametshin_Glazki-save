<Page x:Class="Muhametshin_Глазки_save.AgentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Muhametshin_Глазки_save"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AgentPage" MinHeight="450" MinWidth="800" FontFamily="Century Gothic">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Name="PanelTop">
        <Grid Grid.Row="0" Background="#FFE9F9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
                <ColumnDefinition Width="auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="10,5,0,5" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="Введите для поиска" HorizontalAlignment="Left" FontSize="15"></TextBlock>
                <TextBox VerticalContentAlignment="Center" Name="TBoxSearch" TextChanged="TBoxSearch_TextChanged" Height="25" FontSize="15" Width="250"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,5,0,5" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="Сортировка" HorizontalAlignment="Center" FontSize="15"></TextBlock>
                <ComboBox Name="ComboSort" SelectionChanged="ComboSort_SelectionChanged" Height="25" FontSize="15" Width="200">
                    <TextBlock> Все записи</TextBlock>
                    <TextBlock> Наименование по возрастанию</TextBlock>
                    <TextBlock> Наименование по убыванию</TextBlock>
                    <Separator BorderThickness="1" BorderBrush="LightGray"></Separator>
                    <TextBlock> Скидка по возрастанию</TextBlock>
                    <TextBlock> Скидка по убыванию</TextBlock>
                    <Separator BorderThickness="1" BorderBrush="LightGray"></Separator>
                    <TextBlock> Приоритет по возрастанию</TextBlock>
                    <TextBlock> Приоритет по убыванию</TextBlock>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="10,5,0,5" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="Все типы" HorizontalAlignment="Center" FontSize="15"></TextBlock>
                <ComboBox Name="ComboType" SelectionChanged="ComboType_SelectionChanged" Height="25" FontSize="15" Width="150">
                    <TextBlock> Все типы</TextBlock>
                    <TextBlock> ЗАО</TextBlock>
                    <TextBlock> МКК</TextBlock>
                    <TextBlock> МФО</TextBlock>
                    <TextBlock> ОАО</TextBlock>
                    <TextBlock> ООО</TextBlock>
                    <TextBlock> ПАО</TextBlock>
                </ComboBox>
            </StackPanel>
        </Grid>
            <StackPanel Name="PanelEditPriority" Visibility="Collapsed">
                <Separator Background="LightGray"></Separator>
                <Grid Margin="16 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button Name="BtnEditAgentPriority" Content="Изменить приоритет на ..."
                            Grid.Column="1" Click="BtnEditAgentPriority_Click"></Button>

                    <TextBlock Name="TBlockNumSelected"
                               VerticalAlignment="Center" Grid.Column="0" Opacity="0.4"></TextBlock>
                </Grid>
            </StackPanel>
        </StackPanel>
        <ListView Name="AgentListView" SelectionChanged="AgentListView_SelectionChanged" Grid.Row="1">
            <ListView.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="Редактировать агента" Click="MenuItem_Click"></MenuItem>
                    <MenuItem Header="Добавить агента" Click="BtnAddAgent_Click"></MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1">
                        <Grid Background="{Binding FonStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"></ColumnDefinition>
                                <ColumnDefinition Width="500"></ColumnDefinition>
                                <ColumnDefinition Width="60"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!--<Image Width="200" Grid.Column="0" Grid.RowSpan="4" Stretch="UniformToFill" HorizontalAlignment="Center">
                                <Image.Source>
                                    <Binding Path="AgentPhotoPath">
                                        <Binding.TargetNullValue>
                                            <ImageSource>
                                                Resources/picture.png
                                            </ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>-->
                            <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="4" Height="100" Stretch="Uniform" Margin="10">
                                <Image.Source>
                                    <Binding Path="AgentPhotoPath">
                                        <Binding.TargetNullValue>
                                            <ImageSource>
                                                Resources/picture.png
                                            </ImageSource>
                                        </Binding.TargetNullValue>
                                    </Binding>
                                </Image.Source>
                            </Image>
                            
                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding AgentType.Title}" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                                <TextBlock Text="|" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                                <TextBlock Text="{Binding Title}" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding SalesForYear}" FontSize="16"></TextBlock>
                                <TextBlock Text=" продаж за год" FontSize="16"></TextBlock>
                            </StackPanel>
                            <TextBlock Text="{Binding Phone}" Grid.Column="1" Grid.Row="2" FontSize="16"></TextBlock>
                            <TextBlock Text="{Binding Priority, StringFormat=Приоритетность: {0}}" Grid.Column="1" Grid.Row="3" FontSize="16"></TextBlock>
                            <TextBlock Text="{Binding Discount, StringFormat= {} {0} %}" Grid.Column="2" Grid.Row="0" FontSize="20" ></TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Name="TBlockNumRecords" VerticalAlignment="Center" Opacity="0.4"></TextBlock>
            <Button Name="LeftDirButton" Content="&lt;" Width="20" Height="20" Click="LeftDirButton_Click"></Button>
            <ListBox FontSize="20" Name="PageListBox" SelectionChanged="PageListBox_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirButton" Content="&gt;" Width="20" Height="20" Click="RightDirButton_Click"></Button>
        </StackPanel>
    </Grid>
</Page>
