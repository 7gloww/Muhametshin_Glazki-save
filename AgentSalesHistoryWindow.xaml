<Window x:Class="Muhametshin_Глазки_save.AgentSalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Muhametshin_Глазки_save"
        mc:Ignorable="d"
        Title="AgentSalesHistoryWindow" Height="450" Width="800" FontFamily="Century Gothic">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"></Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Name="GridTop" Grid.Row="0" Margin="10 10 10 14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Товар:" Margin="0 0 0 4"></TextBlock>
                <ComboBox Name="CBoxProducts" Margin="0 0 10 0" DisplayMemberPath="Title" 
                          IsEditable="True" VerticalAlignment="Center"
                          TextSearch.TextPath="Title" Height="25" FontSize="15"></ComboBox>
            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Количество:" Margin="0 0 0 4"></TextBlock>
                    <TextBox Name="TBoxProductCount" Margin="0 0 10 0" Text="1" FontSize="15" Height="25"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Дата:" Margin="0 0 0 4"></TextBlock>
                    <DatePicker Name="DPickerSaleDate" Margin="0 0 10 0" FontSize="15"></DatePicker>
                </StackPanel>

            </Grid>
        </Grid>
        

        <StackPanel Grid.Row="2" HorizontalAlignment="Left" Margin="10">
            <Button Name="BtnAddSale" Content="Добавить" Grid.Row="2" Click="BtnAddSale_Click" VerticalAlignment="Bottom"></Button>
        </StackPanel>

        <ListView Name="ListViewSales" Grid.Row="1"
                  SelectionChanged="ListViewSales_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="Black"></Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridView.ColumnHeaderContainerStyle>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="FontSize" Value="16"></Setter>
                            <Setter Property="Padding" Value="0 4"></Setter>
                        </Style>
                    </GridView.ColumnHeaderContainerStyle>

                    <GridViewColumn Header="Продукт" Width="420" DisplayMemberBinding="{Binding Product.Title}"></GridViewColumn>
                    <GridViewColumn Header="Дата продажи" Width="180" DisplayMemberBinding="{Binding SaleDate, StringFormat=d, ConverterCulture=Ru}"></GridViewColumn>
                    <GridViewColumn Header="Количество" Width="140" DisplayMemberBinding="{Binding ProductCount}"></GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Name="PanelBottom" Grid.Row="2" HorizontalAlignment="Right" Margin="10" Visibility="Collapsed">
            <Button Name="BtnDelete" Content="Удалить запись" FontWeight="Normal" Background="{x:Null}" Foreground="Red" 
                        BorderBrush="Red" HorizontalAlignment="Left"
                        VerticalAlignment="Center" Click="BtnDelete_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
